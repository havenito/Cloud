services:
  web:
    build: ./src
    container_name: flask-app
    restart: unless-stopped
    environment:
      DB_HOST: "{{ db_host }}"
      DB_PORT: "{{ db_port }}"
      DB_NAME: "{{ db_name }}"
      DB_USER: "{{ db_user }}"
      DB_PASSWORD: "{{ db_password }}"
    ports:
      - "{{ app_host }}:8000:8000"
